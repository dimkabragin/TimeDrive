# Local private release secrets example for scripts/release_local.sh
# Заполняйте только локально, не коммитьте реальные секреты.

# Sparkle private key (multiline PEM, shell-quoted)
SPARKLE_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_LINE_1
YOUR_PRIVATE_KEY_LINE_2
YOUR_PRIVATE_KEY_LINE_3
-----END PRIVATE KEY-----'

# GitHub publish auth (required only when PUBLISH=1)
GITHUB_TOKEN=ghp_your_token_here
