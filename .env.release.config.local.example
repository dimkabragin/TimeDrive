# Local public/non-secret release config example for scripts/release_local.sh
# Меняйте этот файл между релизами (VERSION, URL, флаги).
VERSION=v1.0.7
GITHUB_REPOSITORY=dimkabragin/TimeDrive

# Sparkle/appcast URLs
SPARKLE_APPCAST_URL=https://dimkabragin.github.io/TimeDrive/appcast.xml
APPCAST_URL=${SPARKLE_APPCAST_URL}
APPCAST_BASE_DOWNLOAD_URL=https://github.com/${GITHUB_REPOSITORY}/releases/download/${VERSION}
RELEASE_NOTES_URL=https://github.com/${GITHUB_REPOSITORY}/releases/tag/${VERSION}

# Public/non-secret Sparkle settings
SPARKLE_PUBLIC_ED_KEY=YOUR_PUBLIC_ED25519_KEY
SPARKLE_SIGN_UPDATE_TOOL=./.build-release/DerivedData/SourcePackages/artifacts/sparkle/Sparkle/bin/sign_update

# Release behavior flags
APPCAST_GENERATE=1
SPARKLE_SIGN_UPDATE=1
PUBLISH=0
NON_INTERACTIVE=1
